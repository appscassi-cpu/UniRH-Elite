
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Perfil do usuário no sistema.",
      "properties": {
        "id": { "type": "string" },
        "nome": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "perfil": { "type": "string", "enum": ["admin", "usuario"] },
        "dataCriacao": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "nome", "email", "perfil", "dataCriacao"]
    },
    "Staff": {
      "title": "Staff",
      "type": "object",
      "description": "Dados cadastrais do servidor escolar.",
      "properties": {
        "id": { "type": "string" },
        "nome": { "type": "string" },
        "matricula": { "type": "string" },
        "cargo": { "type": "string" },
        "setor": { "type": "string" },
        "telefone": { "type": "string" },
        "dataAdmissao": { "type": "string", "format": "date" },
        "observacao": { "type": "string" },
        "dataCadastro": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "nome", "matricula", "cargo", "setor", "dataAdmissao", "dataCadastro"]
    },
    "Occurrence": {
      "title": "Occurrence",
      "type": "object",
      "description": "Registro de ocorrência de um servidor.",
      "properties": {
        "id": { "type": "string" },
        "servidorId": { "type": "string" },
        "servidorNome": { "type": "string" },
        "tipo": { "type": "string" },
        "dataInicio": { "type": "string", "format": "date" },
        "dataFim": { "type": "string", "format": "date" },
        "dias": { "type": "number" },
        "observacao": { "type": "string" },
        "anexo": { "type": "string", "format": "uri" },
        "dataRegistro": { "type": "string", "format": "date-time" },
        "usuarioRegistro": { "type": "string" }
      },
      "required": ["id", "servidorId", "servidorNome", "tipo", "dataInicio", "dataFim", "dias", "dataRegistro", "usuarioRegistro"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/usuarios/{userId}": {
      "schema": "User",
      "description": "Perfis de usuários do sistema."
    },
    "/roles_admin/{userId}": {
      "schema": "User",
      "description": "Coleção auxiliar para verificação rápida de privilégios admin."
    },
    "/servidores/{staffId}": {
      "schema": "Staff",
      "description": "Cadastro de servidores escolares."
    },
    "/ocorrencias/{occurrenceId}": {
      "schema": "Occurrence",
      "description": "Histórico de ocorrências dos servidores."
    }
  }
}
