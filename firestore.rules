
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Funções Auxiliares
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isRegistered() {
      return isSignedIn() && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid));
    }

    // Regras para Usuários
    match /usuarios/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow update, delete: if isAdmin();
    }

    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if false; // Gerenciado apenas via Admin SDK/Console
    }

    // Regras para Servidores
    match /servidores/{id} {
      allow read: if isRegistered();
      allow create, update, delete: if isAdmin();
    }

    // Regras para Ocorrências
    match /ocorrencias/{id} {
      allow read: if isRegistered();
      allow create: if isRegistered();
      allow update, delete: if isAdmin();
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
